1484. Group Sold Products By The Date

SELECT
    to_char(sell_date,'yyyy-mm-dd') as sell_date,
    COUNT(DISTINCT product) AS num_sold,
    LISTAGG(product, ',') WITHIN GROUP (ORDER BY product) AS products
FROM (
    SELECT DISTINCT
        sell_date,
        product
    FROM Activities
)
GROUP BY sell_date
ORDER BY sell_date;
